{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Java Tests",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                ".vscode/compile-tests.ps1"
            ],
            "group": "build",
            "problemMatcher": "$javac"
        },
        {
            "label": "Run JUnit Tests",
            "type": "shell",
            "command": "C:\\Program Files\\Java\\jdk1.8.0_202\\bin\\java.exe",
            "args": [
                "-jar",
                "lib/junit-platform-console-standalone-1.10.2.jar",
                "execute",
                "--class-path",
                "bin/classes;bin/test-classes",
                "--scan-class-path"
            ],
            "dependsOn": "Compile Java Tests",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
